# Cloudflare redirect rules
# Order matters — first match wins.
#
# IMPORTANT: Cloudflare's asset server automatically strips "index.html" and
# ".html" suffixes when resolving paths. A rule that redirects to a literal
# "index.html" path gets re-processed by that auto-stripping and matches the
# same rule again, causing an infinite loop ("Line N: Infinite loop detected").
# The fix is to redirect to the directory path (with trailing slash) instead
# of the literal file — Cloudflare serves index.html for a directory path
# without re-triggering the redirect rule.

# Legacy bare paths → redirect to the /app/ prefix so old bookmarks and
# any links from the old landing page still work.
/login   /app/login   301
/signup  /app/signup  301

# All /app/* routes → React app (SPA fallback)
# Lets React Router handle /app/login, /app/dashboard, /app/accept-invite etc.
/app    /app/  200
/app/*  /app/  200

# Root and all other paths → landing page
/*      /       200
